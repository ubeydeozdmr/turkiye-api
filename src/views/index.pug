block scripts
  script.
    (function () {
      var overlay = document.getElementById('v2-modal-overlay');
      var modal = overlay.querySelector('[role="dialog"]');
      var dismissed = localStorage.getItem('v2ModalDismissed');
      var previouslyFocused = null;
      var focusableSelectors = 'a[href], button:not([disabled]), input:not([disabled]), textarea:not([disabled]), select:not([disabled]), [contenteditable="true"], [tabindex]:not([tabindex="-1"])';

      function getFocusable() {
        return Array.prototype.slice.call(modal.querySelectorAll(focusableSelectors));
      }

      function openModal() {
        overlay.classList.remove('hidden');
        previouslyFocused = document.activeElement;
        var focusable = getFocusable();
        if (focusable.length) {
          focusable[0].focus();
        } else {
          modal.focus();
        }
      }

      function closeModal() {
        overlay.classList.add('hidden');
        if (previouslyFocused) {
          previouslyFocused.focus();
        }
      }

      function trapFocus(e) {
        if (e.key !== 'Tab') return;
        var focusable = getFocusable();
        if (!focusable.length) return;
        var first = focusable[0];
        var last = focusable[focusable.length - 1];
        if (e.shiftKey) {
          if (document.activeElement === first) {
            e.preventDefault();
            last.focus();
          }
        } else {
          if (document.activeElement === last) {
            e.preventDefault();
            first.focus();
          }
        }
      }

      if (!dismissed) {
        openModal();
      }

      overlay.addEventListener('keydown', function (e) {
        if (e.key === 'Escape') closeModal();
        trapFocus(e);
      });

      document.getElementById('v2-modal-dismiss').addEventListener('click', function () {
        var noShow = document.getElementById('v2-modal-no-show').checked;
        if (noShow) {
          localStorage.setItem('v2ModalDismissed', '1');
        }
        closeModal();
      });

      overlay.addEventListener('click', function (e) {
        if (e.target === overlay) {
          var noShow = document.getElementById('v2-modal-no-show').checked;
          if (noShow) {
            localStorage.setItem('v2ModalDismissed', '1');
          }
          closeModal();
        }
      });
    })();

    hljs.highlightAll();

    const origin = window.location.origin;

    document.querySelector('p.playground__url--host#lg').innerHTML = origin + '/v1/';

    async function init() {
      try {
        const res = await fetch('/v1/provinces?name=istanbul');
        const data = await res.json();
        document.querySelector('.playground__panel--content code').innerHTML =
          JSON.stringify(data, null, 2);
        hljs.highlightAll();
      } catch (error) {
        console.error(error);
      }
    }

    document
      .querySelector('a[href="#content"]')
      .addEventListener('click', event => {
        event.preventDefault();
        document.querySelector('#content').scrollIntoView({
          behavior: 'smooth',
        });
      });

    document
      .querySelector('.playground__url--input')
      .addEventListener('keyup', event => {
        if (event.keyCode === 13) document.querySelector('.playground__url--submit').click();
      });

    document
      .querySelector('.playground__url--copy')
      .addEventListener('click', event => {
        event.preventDefault();
        const input = document.querySelector('.playground__url--input');
        const text = input.value;
        input.value = `${origin}/v1/${input.value}`;
        input.select();
        input.setSelectionRange(0, 99999);
        document.execCommand('copy');
        input.value = text;
      });

    document
      .querySelector('.playground__url--submit')
      .addEventListener('click', event => {
        event.preventDefault();
        document.querySelector('.playground__panel--content code').innerHTML = 'Loading...';
        const input = document.querySelector('.playground__url--input').value;
        const url = `/v1/${input}`;
        fetch(url)
          .then(res => res.json())
          .then(data => {
            document.querySelector('.playground__panel--content code').innerHTML =
              JSON.stringify(data, null, 2);
            hljs.highlightAll();
          })
      });

    document
      .querySelector('.playground__newtab--link')
      .addEventListener('click', event => {
        event.preventDefault();
        const input = document.querySelector('.playground__url--input').value;
        const url =  `${origin}/v1/${input}`;
        window.open(url, '_blank');
      });

    document.querySelectorAll('.playground__hint--link').forEach(link => {
      link.addEventListener('click', event => {
        event.preventDefault();
        document.querySelector('.playground__url--input').value = link.innerHTML;
        document.querySelector('.playground__url--submit').click();
      });
    });

    init();