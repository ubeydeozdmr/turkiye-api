{
  "name": "turkiye-api",
  "version": "2.0.0",
  "description": "Get Turkish administrative divisions data (provinces, districts, neighborhoods, villages) via a fast REST API.",
  "keywords": [
    "turkiye",
    "turkey",
    "api",
    "rest-api",
    "geodata",
    "location-data",
    "provinces",
    "districts",
    "neighborhoods",
    "villages",
    "cities",
    "administrative-divisions",
    "turkish-data",
    "nodejs",
    "fastify"
  ],
  "author": "Ubeyde Emir Özdemir <ubeydeozdmr@gmail.com> (https://ubeyde.me)",
  "license": "MIT",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "node --import tsx --test \"tests/**/*.test.ts\"",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=22.22.2 <23"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/rate-limit": "^10.3.0",
    "fastify": "^5.8.5",
    "typebox": "^1.1.34"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  },
  "private": false,
  "repository": {
    "type": "git",
    "url": "https://github.com/ubeydeozdmr/turkiye-api"
  },
  "bugs": {
    "url": "https://github.com/ubeydeozdmr/turkiye-api/issues"
  },
  "homepage": "https://github.com/ubeydeozdmr/turkiye-api#readme"
}
